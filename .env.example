# Configuration pour immothies-dakar-auto-indexer
# Copiez ce fichier en .env et remplissez les valeurs

# Google Service Account JSON (coller le contenu complet)
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# IndexNow Key (générée sur https://www.bing.com/indexnow)
INDEXNOW_KEY=votre-cle-indexnow-ici

# Site à indexer
SITE_URL=https://immothies-dakar.com

# Options d'indexation
PRIORITY_ONLY=false
SKIP_GOOGLE=false
SKIP_INDEXNOW=false

# Notifications (optionnel)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Mode debug
DEBUG=false
